# ============================================================
# Learning Engine – Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values below.
# NEVER commit your actual .env.local to source control.
# ============================================================

# ----------------------------------------------------------
# Google AI Studio API Key (OPTIONAL – host-level override)
# If set, ALL users share this key (no per-user key needed).
# If NOT set, each user provides their own key via Settings
# (BYOK – Bring Your Own Key). Get a key at:
# https://aistudio.google.com/apikey
# ----------------------------------------------------------
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_studio_key_here

# ----------------------------------------------------------
# Supabase (required for auth + conversation persistence)
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ----------------------------------------------------------
# Database – Supabase PostgreSQL with pgvector (required for
# conversation history and the memory system)
# ----------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ----------------------------------------------------------
# Encryption secret for user API keys stored at rest (required)
# Used with AES-256-CBC to encrypt per-user keys before DB storage.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ----------------------------------------------------------
API_KEY_ENCRYPTION_SECRET=your_64_char_hex_string_here

